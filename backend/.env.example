# 复制为 .env 并按需修改。.env 不会被提交到 git。

# ── 运行环境 ──────────────────────────────────
# development | production
ENV=development
# 日志级别：DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ── 服务监听 ──────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── 数据库 ────────────────────────────────────
# MVP 早期用 SQLite；上线前切 MySQL，例如：
# DATABASE_URL=mysql+aiomysql://user:pass@127.0.0.1:3306/aipeiwan
DATABASE_URL=sqlite+aiosqlite:///./data/aipeiwan.db

# ── CORS ──────────────────────────────────────
# 允许的前端来源，逗号分隔
CORS_ORIGINS_RAW=http://localhost:5173,http://127.0.0.1:5173

# ── 认证 ──────────────────────────────────────
# JWT 签名密钥，生产环境务必改成随机长串：
#   python3 -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=dev-insecure-secret-change-me
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=30

# ── 试用额度 ──────────────────────────────────
# 新用户注册一次性发放的免费秒数
TRIAL_SECONDS=180
# 兑换码奖励秒数（注册时填写有效兑换码额外发放）
REDEEM_CODE_BONUS_SECONDS=1800
# 管理接口创建兑换码用的 token；生产环境务必改成长随机串
ADMIN_TOKEN=dev-admin-token-change-me

# ── 火山引擎 · 语音技术（TTS + 流式 ASR + 端到端实时语音模型 共用一组凭证）──
# 控制台 → 语音技术 → 应用管理 → 你的应用(default)
# 三个产品(TTS / ASR / 端到端实时语音)在同一应用下勾选开通,凭证不变。
VOLC_APP_ID=
VOLC_ACCESS_TOKEN=
# TTS 默认配置
TTS_SAMPLE_RATE=24000
TTS_ENCODING=mp3
# 角色 DB 中 voice_id 为空时的回落音色（湾湾小何 · 甜美女声）
TTS_DEFAULT_VOICE_ID=zh_female_wanwanxiaohe_moon_bigtts

# 端到端实时语音(豆包·Realtime Voice) —— 全双工低延迟对话
# 开通后无需额外 key,沿用 VOLC_APP_ID / VOLC_ACCESS_TOKEN;切海外/换 region 改下面两个
REALTIME_WS_URL=wss://openspeech.bytedance.com/api/v3/realtime/dialogue
REALTIME_RESOURCE_ID=volc.speech.dialog

# ── 火山方舟 · 文本大模型（LLM）──
# 控制台 → 火山方舟 → API Key 管理
ARK_API_KEY=
# 新版协议直接用模型名调用；老协议留 ARK_ENDPOINT_ID（形如 ep-xxxxxx），二选一
ARK_MODEL=doubao-seed-1-6-250615
ARK_ENDPOINT_ID=
# 单轮回复 token 上限（陪玩场景要短）
ARK_MAX_TOKENS=120
ARK_TEMPERATURE=0.85
